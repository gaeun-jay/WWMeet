# Supabase — 프로젝트 Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 관리자 비밀번호 SHA-256 해시값
# 생성 방법: python3 -c "import hashlib; print(hashlib.sha256('원하는비밀번호'.encode()).hexdigest())"
ADMIN_PASSWORD_HASH=해시값

# JWT 서명 시크릿 — 32자 이상 랜덤 문자열
# 생성 방법: openssl rand -base64 32
ADMIN_JWT_SECRET=랜덤문자열32자이상
